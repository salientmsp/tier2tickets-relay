{
  "name": "tier2tickets-relay",
  "version": "1.0.0",
  "description": "Cloudflare Worker that impersonates a HaloPSA instance so Tier2Tickets / Helpdesk Buttons can create tickets in Gorelo.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.2",
    "@cloudflare/workers-types": "^5.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "4.107.1"
  },
  "dependencies": {
    "@ambersecurityinc/notifly": "^0.6.0"
  }
}
