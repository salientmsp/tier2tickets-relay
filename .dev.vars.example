# Copy to .dev.vars for `wrangler dev`. NEVER commit .dev.vars (it holds secrets).
# These map to the CLI-only secrets in production.

# X-API-Key sent to Gorelo. Needs scopes: ticket write, asset/contact/client read.
GORELO_API_KEY="your-gorelo-api-key"

# Gates POST /admin/sync (sent as X-Admin-Key, X-API-Key, or Authorization: Bearer).
ADMIN_KEY="another-long-random-secret"

# Optional: notifly (Apprise-style) URL(s) alerted when a queued ticket is
# dead-lettered (dropped after MAX_PENDING_ATTEMPTS failed Gorelo creates). One or
# more, comma/space separated. Leave unset to only log the drop.
# e.g. ntfy://alerts  |  slack://a/b/c/%23chan  |  Teams Workflows: take the Power
# Automate webhook URL and swap https -> workflows:
#   workflows://<env>.environment.api.powerplatform.com/powerautomate/.../invoke?...&sig=...
# The notifly Playground (https://notifly.sh/docs/builder/playground/) does this
# https -> workflows:// conversion client-side (nothing leaves your browser).
# NOTIFLY_URLS="ntfy://my-hdb-alerts"

# Optional: per-product Halo mock OAuth credentials (issue #51). Each product
# authenticates with its OWN client_id, so credentials are resolved per matched
# product. When both the id AND secret are set for a product, the /token endpoint
# validates them and (under HALO_TOKEN_ENFORCE) its resource requests are token-
# enforced; otherwise that product stays lenient (any creds accepted — still IP-gated).
# Set the same values on that product's Halo integration side.
#
# tier2 uses the original un-suffixed pair:
HALO_CLIENT_ID="halo-mock-client-id"
HALO_CLIENT_SECRET="halo-mock-client-secret"
# Huntress uses its own (its distinct client_id). Uncomment to enable validation:
# HALO_CLIENT_ID_HUNTRESS="13b3832f9306b677fb72eea412da5df7"
# HALO_CLIENT_SECRET_HUNTRESS="huntress-mock-client-secret"
